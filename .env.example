# Veritabanı
DATABASE_URL="postgresql://user:password@localhost:5432/meeting_assistant"
REDIS_URL="redis://localhost:6379"

# Recall.ai
RECALL_API_KEY="your_recall_api_key"
WEBHOOK_BASE_URL="https://sizin-domain.com"

# OpenAI
OPENAI_API_KEY="your_openai_api_key"

# Supabase
SUPABASE_URL="your_supabase_url"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_KEY="your_supabase_service_key"

# Slack (OAuth App)
SLACK_CLIENT_ID="your_slack_client_id"
SLACK_CLIENT_SECRET="your_slack_client_secret"

# Notion (OAuth App)
NOTION_CLIENT_ID="your_notion_client_id"
NOTION_CLIENT_SECRET="your_notion_client_secret"

# Slack varsayılan kanal (opsiyonel)
SLACK_DEFAULT_CHANNEL="#genel"

# Notion database ID (opsiyonel)
NOTION_DATABASE_ID="your_notion_database_id"

# Frontend
VITE_API_URL="http://localhost:3000"
VITE_SUPABASE_URL="your_supabase_url"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
VITE_SLACK_CLIENT_ID="your_slack_client_id"
VITE_NOTION_CLIENT_ID="your_notion_client_id"
